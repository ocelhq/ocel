// Local development workspace for the Ocel multi-module monorepo.
//
// There is no module at the repo root — each unit is its own module so their
// dependency graphs stay isolated:
//   ./cli        -> github.com/ocelhq/ocel/cli        (the CLI; heavy deps)
//   ./pkg/proto  -> github.com/ocelhq/ocel/pkg/proto  (lean shared bindings)
//   ./sdk        -> github.com/ocelhq/ocel/sdk        (lean public SDK)
//   ./cloud/aws  -> github.com/ocelhq/ocel/cloud/aws  (provider binary; heavy AWS SDK)
//   ./cloud/edge -> github.com/ocelhq/ocel/cloud/edge (lean edge contract)
//   ./cloud/edge/cloudflare -> .../cloud/edge/cloudflare (Cloudflare edge; cloudflare-go)
//
// This file is dev-only and never published. Each consuming module pins the
// shared proto module to the local checkout via a `replace` in its own go.mod
// (proto has no published tag yet); this workspace just lets you build/edit all
// modules together. Released consumers use pinned require versions instead.
go 1.25.11

use (
	./cli
	./cloud/aws
	./cloud/edge
	./cloud/edge/cloudflare
	./pkg/channel
	./pkg/proto
	./sdk
)

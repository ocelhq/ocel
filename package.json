{
  "name": "ocelhq",
  "description": "Ocel monorepo",
  "scripts": {
    "gen": "buf generate --template buf.gen.go.yaml && pnpm buf generate --template buf.gen.ts.yaml",
    "dev:cli": "cd ocel && go tool air",
    "ci:version": "changeset version && pnpm install --lockfile-only"
  },
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.71.0",
    "@bufbuild/protobuf": "^2.12.1",
    "@bufbuild/protoc-gen-es": "^2.12.1",
    "@changesets/cli": "^2.31.0",
    "@connectrpc/validate": "^0.2.0"
  }
}

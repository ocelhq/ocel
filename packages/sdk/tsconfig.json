{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "esnext",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // Relative imports carry explicit .js extensions in source (and
    // verbatimModuleSyntax emits them unchanged), so dist loads under plain
    // `node`, not only a bundler. Resolution stays "bundler" because some
    // optional-peer types (e.g. next/server) don't resolve under nodenext.
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": false,

    // outDir
    "rootDir": "./src",
    "outDir": "dist",
    "emitDeclarationOnly": false,
    "declaration": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/__tests__/*.ts",
    "src/**/*.test.ts",
    "src/**/*.test-d.ts"
  ]
}

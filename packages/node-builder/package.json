{
  "name": "@ocel/node-builder",
  "version": "0.0.1-alpha.0",
  "private": true,
  "type": "module",
  "description": "JS build engine: traces + transpiles an Express app into a serverless .func artifact",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "gen:shim": "node scripts/gen-shim.mjs",
    "build": "node build.mjs",
    "pretest": "node scripts/gen-shim.mjs",
    "test": "vitest run",
    "pretypecheck": "node scripts/gen-shim.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vercel/nft": "^0.27.4",
    "serverless-http": "^3.2.0",
    "sucrase": "^3.35.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^20",
    "esbuild": "^0.24.2",
    "express": "~5.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "license": "MIT"
}

{
  "name": "ocel",
  "version": "0.0.1-alpha.0",
  "type": "module",
  "description": "ocel cli — turns cloud infrastructure into function calls",
  "bin": {
    "ocel": "./bin/run.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@vercel/nft": "^0.27.4",
    "es-module-lexer": "^1.5.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "express": "~5.0.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@ocel/darwin-arm64": "workspace:^",
    "@ocel/darwin-x64": "workspace:^",
    "@ocel/linux-x64": "workspace:^",
    "@ocel/win32-x64": "workspace:^"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}

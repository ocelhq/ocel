# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Database (PostgreSQL) - see root docker-compose.yml
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Test database (Vitest test harness) - separate DB on the same local Postgres
# instance; created automatically by the test harness if it doesn't exist yet.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/ocelhq_test

# Cloud cluster admin connection (PostgreSQL) - see root docker-compose.yml's
# `ocel-cloud` service, a separate Postgres instance standing in for Aurora
# Serverless v2 in prod. Resolve (POST /api/resources/resolve) connects here
# as admin to carve out a per-user role+database on first request.
OCEL_CLOUD_ADMIN_URL=postgres://postgres:postgres@localhost:5433/postgres

# GitHub OAuth
# Create an OAuth app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
